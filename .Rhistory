},
lowerLimit = c(a1, a2),
upperLimit = c(b1, b2)
)
true_total <- res$integral
true_mean  <- true_total / Area
# exhaustive mean (make fast MC approximation for better stability)
N_large <- 1e7
x1_big <- runif(N_large, a1, b1)
x2_big <- runif(N_large, a2, b2)
Z_big <- cbind(
x1_big,
x2_big,
x1_big^2,
x1_big*x2_big,
x2_big^2
)
exhaustive_mean_df <- colMeans(Z_big)
names(exhaustive_mean_df) <- c("x1", "x2", "x1_sq", "x1x2", "x2_sq")
exhaustive_mean_df <- as.data.frame(t(exhaustive_mean_df))
# --- Estimators ---
one_phase <- function(y, w, alpha = 0.05,
ci_method = c("normal", "t"),
type = c("mean", "total"),
surface_area = NULL) {
ci_method <- match.arg(ci_method)
type <- match.arg(type)
# --- Remove NAs consistently ---
keep <- !is.na(y) & !is.na(w)
y <- y[keep]
w <- w[keep]
n <- length(y)
if (n < 2) stop("Need at least 2 non-missing observations")
# --- Design-based mean ---
mu_hat <- weighted.mean(y, w = w)
# --- Average weight ---
bar_W <- mean(w)
# --- Variance estimator ---
var_hat <- (1 / n) * (1 / (n - 1)) *
sum(((w / bar_W)^2) * (y - mu_hat)^2)
# --- Scale if total requested ---
if (type == "total") {
if (is.null(surface_area)) stop("surface_area must be provided for totals")
mu_hat <- mu_hat * surface_area
var_hat <- var_hat * (surface_area^2)
}
# --- Confidence intervals ---
se_hat <- sqrt(var_hat)
if (ci_method == "normal") {
crit <- qnorm(1 - alpha / 2)
} else {
crit <- qt(1 - alpha / 2, df = n - 1)
}
ci_lower <- mu_hat - crit * se_hat
ci_upper <- mu_hat + crit * se_hat
# --- Return ---
list(
estimate = mu_hat,
variance = var_hat,
se = se_hat,
ci = c(lower = ci_lower, upper = ci_upper),
n = n,
type = type,
ci_method = ci_method,
alpha = alpha
)
}
# True external model
sae_external <- function(ext_model_obj, data, small_area, exhaustive_mean_df,
surface_area, type = c("mean", "total"),
alpha = 0.05, ci_method = c("normal", "t")) {
type <- match.arg(type)
ci_method <- match.arg(ci_method)
# --- Extract fitted coefficients from model ---
beta_hat <- coef(ext_model_obj)
# --- Synthetic prediction part ---
y_syn <- predict(ext_model_obj, newdata = exhaustive_mean_df)
# --- Residual correction for small area ---
mf <- model.frame(ext_model_obj, data = data)   # align to model
y <- model.response(mf)
X <- model.matrix(ext_model_obj, data = data)
weights <- model.weights(mf)
idx_sa <- which(small_area == 1)
X_sa <- X[idx_sa, , drop = FALSE]
y_sa <- y[idx_sa]
w_sa <- weights[idx_sa]
# Residuals in small area
res_sa <- y_sa - as.numeric(X_sa %*% beta_hat)
# Weighted mean of residuals
res_bar <- weighted.mean(res_sa, w_sa)
# --- Final estimate (per hectare) ---
y_ext_hat <- y_syn + res_bar
var_ext <- {
n_sa <- length(idx_sa)
W_bar <- mean(w_sa)
(1 / n_sa) * (1 / (n_sa - 1)) *
sum(((w_sa / W_bar)^2) * (res_sa - res_bar)^2)
}
# Scale both estimate and variance if total is requested
# (variance of total = variance of mean * area^2)
if (type == "total") {
y_ext_hat <- y_ext_hat * surface_area
var_ext <- var_ext * (surface_area^2)
}
# --- Confidence intervals ---
se_ext <- sqrt(var_ext)
if (ci_method == "normal") {
crit <- qnorm(1 - alpha / 2)
} else {
n_sa <- length(idx_sa)
crit <- qt(1 - alpha / 2, df = n_sa - 1)
}
ci_lower <- y_ext_hat - crit * se_ext
ci_upper <- y_ext_hat + crit * se_ext
list(
coefficients = beta_hat,
estimate = y_ext_hat,
variance = var_ext,
se = se_ext,
ci = c(lower = ci_lower, upper = ci_upper),
n_sa = length(idx_sa),
n = length(ext_model_obj$residuals),
type = type,
ci_method = ci_method,
alpha = alpha
)
}
# REG internal
g_weight_internal <- function(model_obj, data, small_area,
exhaustive_mean_df,
ci_method = c("normal", "t"),
alpha = 0.05,
type = c("mean", "total"),
surface_area = NULL,
allow_bias = FALSE) {
ci_method <- match.arg(ci_method)
type <- match.arg(type)
# --- Extract model pieces ---
mf <- model.frame(model_obj, data = data)
y <- model.response(mf)
X <- model.matrix(model_obj, data = data)
w <- model.weights(mf)
p <- ncol(X)
# restrict to non-missing
keep <- !is.na(y) & !is.na(w)
y <- y[keep]; X <- X[keep, , drop = FALSE]; w <- w[keep]
small_area <- small_area[keep]
# --- Global regression fit ---
n_total <- nrow(X)
As2inv <- solve( (t(X) %*% (w * X)) / n_total )
theta_hat <- drop( ((w * y) %*% X / n_total) %*% As2inv )  # regression coefficients
# fitted and residuals
y_hat <- as.vector(X %*% theta_hat)
res <- y - y_hat
# covariance matrix of coefficients
WR_sq <- (w^2) * (res^2)  # this is M^2(x) * R_hat(x)^2 in Eq. 11 of Hill et al. 2018 (DOI: 10.3390/rs10071052)
# middle_term <- (t(X) %*% (WR_sq * X)) / (n_total^2)
middle_term <- (t(X) %*% (WR_sq * X)) / (n_total*(n_total-p))
cov_theta <- As2inv %*% middle_term %*% As2inv
# --- Small area subset ---
idx_sa <- which(small_area == 1)
X_sa <- X[idx_sa, , drop = FALSE]
y_sa <- y[idx_sa]
w_sa <- w[idx_sa]
n_sa <- length(idx_sa)
res_sa <- res[idx_sa]
res_bar_sa <- weighted.mean(res_sa, w_sa) # should be zero by construction
if(!allow_bias){
if (round(res_bar_sa,3)!=0) stop("Mean residual not zero, did you forget the small area indicator variable?")
}
# --- Synthetic part (using exhaustive mean vector) ---
# extract RHS of formula (predictors only)
rhs_formula <- reformulate(attr(terms(model_obj), "term.labels"))
# build design row from exhaustive means based on hs_formula (response is unknown...)
Z_bar <- as.numeric(model.matrix(rhs_formula, data = exhaustive_mean_df))
names(Z_bar) <- colnames(X)
syn_part <- sum(Z_bar * theta_hat)
# --- Final estimate ---
est <- syn_part
if (type == "total") {
if (is.null(surface_area)) stop("surface_area must be provided for type = 'total'")
est <- est * surface_area
}
# --- Variance parts ---
g_var <- drop(t(Z_bar) %*% cov_theta %*% Z_bar)
ext_var <- (1/n_sa) * (1/(n_sa - 1)) *
sum(((w_sa / mean(w_sa))^2) * (res_sa - res_bar_sa)^2)
if (type == "total") {
g_var <- g_var * (surface_area^2)
ext_var <- ext_var * (surface_area^2)
}
se <- sqrt(g_var)
# --- CI ---
if (ci_method == "normal") {
z <- qnorm(1 - alpha/2)
ci <- est + c(-1, 1) * z * se
} else {
df <- n_sa - 1
tval <- qt(1 - alpha/2, df = df)
ci <- est + c(-1, 1) * tval * se
}
# --- Output ---
list(
coefficients = theta_hat,
estimate = est,
variance = g_var,
ext_variance = ext_var,
se = se,
ci = ci,
n_sa = n_sa,
n = n_total,
type = type,
ci_method = ci_method
)
}
# --- Simulation parameters ---
methods <- c("One_phase",
"Two_phase_external_full",
"Two_phase_internal_full")
results <- expand.grid(
Estimator = methods,
CI = c("normal","t"),
stringsAsFactors = FALSE
)
results$n          <- n
results$EmpMean    <- NA
results$EmpVar     <- NA
results$MeanVarEst <- NA
results$Coverage   <- NA
store <- lapply(methods, function(x)
list(est=numeric(MC),
var=numeric(MC),
cover=matrix(FALSE,MC,2)))
names(store) <- methods
# =====================================================
# MONTE CARLO LOOP
# =====================================================
for(i in 1:MC){
x1 <- runif(n,0,2)
x2 <- runif(n,0,3)
y <- Y_fun(x1,x2)  # Evaluate sample points with truth
w <- rep(1,n)
data_df <- data.frame(
y = y,
x1 = x1,
x2 = x2,
x1_sq = x1^2,
x1x2 = x1*x2,
x2_sq = x2^2,
w = w
)
# model <- lm(y ~ x1 + x2 + x1_sq + x1x2 + x2_sq,
#             data = data_df,
#             weights = w)
model <- lm(y ~ 1,
data = data_df,
weights = w)
if(!run_small_area){small_area <- rep(1,n)}   # whole domain = target area
else{small_area <- rep(1,n)}
# =====================================================
# 1) ONE-PHASE
# =====================================================
for(ci_id in 1:2){
ci_type <- c("normal","t")[ci_id]
fit <- one_phase(
y = y,
w = w,
ci_method = ci_type,
type = "mean",
surface_area = Area
)
store$One_phase$est[i] <- fit$estimate
store$One_phase$var[i] <- fit$variance
store$One_phase$cover[i,ci_id] <-
true_mean >= fit$ci[1] &
true_mean <= fit$ci[2]
}
# =====================================================
# 2) TWO-PHASE EXTERNAL
# =====================================================
for(ci_id in 1:2){
ci_type <- c("normal","t")[ci_id]
fit_ext <- sae_external(
ext_model_obj = model,
data = data_df,
small_area = small_area,
exhaustive_mean_df = exhaustive_mean_df,
surface_area = Area,
type = "mean",
ci_method = ci_type
)
store$Two_phase_external_full$est[i] <- fit_ext$estimate
store$Two_phase_external_full$var[i] <- fit_ext$variance
store$Two_phase_external_full$cover[i,ci_id] <-
true_mean >= fit_ext$ci[1] &
true_mean <= fit_ext$ci[2]
}
# =====================================================
# 3) TWO-PHASE INTERNAL (REG)
# =====================================================
for(ci_id in 1:2){
ci_type <- c("normal","t")[ci_id]
fit_int <- g_weight_internal(
model_obj = model,
data = data_df,
small_area = small_area,
exhaustive_mean_df = exhaustive_mean_df,
ci_method = ci_type,
type = "mean",
surface_area = Area
)
store$Two_phase_internal_full$est[i] <- fit_int$estimate
store$Two_phase_internal_full$var[i] <- fit_int$variance
store$Two_phase_internal_full$cover[i,ci_id] <-
true_mean >= fit_int$ci[1] &
true_mean <= fit_int$ci[2]
}
}
# =====================================================
# SUMMARY TABLE
# =====================================================
row_id <- 1
results <- results[order(results$Estimator),]
for(m in methods){
for(ci_id in 1:2){
results$EmpMean[row_id]    <- mean(store[[m]]$est)
results$EmpVar[row_id]     <- var(store[[m]]$est)
results$MeanVarEst[row_id] <- mean(store[[m]]$var)
results$Coverage[row_id]   <- mean(store[[m]]$cover[,ci_id])
row_id <- row_id + 1
}
}
results
model_obj$rank
model_obj
